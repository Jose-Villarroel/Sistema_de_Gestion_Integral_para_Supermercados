<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.admin.AdminController"
            stylesheets="@../base.css,@admin.css">

    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">
            <Label text="🛒 MasterMarket" styleClass="top-bar-brand"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label text="Panel de Administrador" styleClass="top-bar-context"/>
            <Button text="Cerrar Sesión"
                    onAction="#cerrarSesion"
                    styleClass="btn-cerrar-sesion"/>
        </HBox>
    </top>

    <left>
        <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
                <VBox styleClass="sidebar" spacing="2">

            <Button fx:id="btnEmpleados" text="👤  Empleados"
                    onAction="#mostrarEmpleados"
                    maxWidth="Infinity"
                    styleClass="sidebar-btn"/>

            <Button fx:id="btnProductos" text="📦  Catálogo"
                    onAction="#mostrarProductos"
                    maxWidth="Infinity"
                    styleClass="sidebar-btn"/>

            <Button fx:id="btnInventario" text="📊  Inventario"
                    onAction="#mostrarInventario"
                    maxWidth="Infinity"
                    styleClass="sidebar-btn"/>

            <Button fx:id="btnClientes" text="👥  Clientes"
                    onAction="#mostrarClientes"
                    maxWidth="Infinity"
                    styleClass="sidebar-btn"/>

            <Button fx:id="btnReportes" text="📋  Reportes"
                    onAction="#mostrarReportes"
                    maxWidth="Infinity"
                    styleClass="sidebar-btn"/>
                </VBox>
            </content>
        </ScrollPane>
    </left>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
                <StackPane fx:id="contenidoCentral" styleClass="content-area">
                    <VBox alignment="CENTER" spacing="16">
                        <Label text="Panel de Administrador" styleClass="welcome-title"/>
                        <Label text="Seleccione una opción del menú" styleClass="welcome-subtitle"/>
                    </VBox>
                </StackPane>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
