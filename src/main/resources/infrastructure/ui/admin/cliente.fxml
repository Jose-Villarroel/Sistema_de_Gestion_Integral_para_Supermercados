<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.admin.ClienteController"
            stylesheets="@clientes.css">

    <top>
        <VBox styleClass="header">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="👥" styleClass="header-icon"/>
                <Label text="Administrar clientes" styleClass="header-title"/>
            </HBox>
            <Separator/>
        </VBox>
    </top>

    <center>
        <VBox spacing="15" styleClass="main-container">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- Tarjetas de resumen -->
            <HBox spacing="15">
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="Total clientes" styleClass="card-label"/>
                    <Label fx:id="lblTotalClientes" text="0" styleClass="card-value"/>
                </VBox>
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="Puntos acumulados (mes)" styleClass="card-label"/>
                    <Label fx:id="lblPuntosAcumulados" text="0" styleClass="card-value-accent"/>
                </VBox>
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="Puntos canjeados (mes)" styleClass="card-label"/>
                    <Label fx:id="lblPuntosCanjeados" text="0" styleClass="card-value-muted"/>
                </VBox>
            </HBox>

            <!-- Contenido principal -->
            <SplitPane dividerPositions="0.35" styleClass="main-split" VBox.vgrow="ALWAYS">

                <!-- Panel formulario -->
                <VBox styleClass="form-panel" spacing="15">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="+ Nuevo cliente" styleClass="btn-nuevo"/>
                    </HBox>

                    <Label text="Datos del cliente" styleClass="section-title"/>

                    <VBox spacing="5">
                        <Label text="Nombre *" styleClass="field-label"/>
                        <TextField fx:id="txtNombre"
                                   promptText="Nombre"
                                   styleClass="text-field"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Apellido *" styleClass="field-label"/>
                        <TextField fx:id="txtApellido"
                                   promptText="Apellido"
                                   styleClass="text-field"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Correo *" styleClass="field-label"/>
                        <TextField fx:id="txtCorreo"
                                   promptText="correo@ejemplo.com"
                                   styleClass="text-field"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Teléfono *" styleClass="field-label"/>
                        <TextField fx:id="txtTelefono"
                                   promptText="3001234567"
                                   styleClass="text-field"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Dirección" styleClass="field-label"/>
                        <TextField fx:id="txtDireccion"
                                   promptText="Dirección (opcional)"
                                   styleClass="text-field"/>
                    </VBox>

                    <HBox spacing="10" alignment="CENTER">
                        <Button text="Registrar"
                                onAction="#registrarCliente"
                                styleClass="btn-primary"
                                prefWidth="100"/>
                        <Button text="Modificar"
                                onAction="#modificarCliente"
                                styleClass="btn-secondary"
                                prefWidth="100"/>
                        <Button text="Limpiar"
                                onAction="#limpiarFormulario"
                                styleClass="btn-clear"
                                prefWidth="100"/>
                    </HBox>

                    <Button text="Desactivar cliente"
                            onAction="#desactivarCliente"
                            styleClass="btn-danger"
                            maxWidth="Infinity"/>

                    <Label text="* Campos obligatorios" styleClass="required-label"/>
                </VBox>

                <!-- Panel tabla -->
                <VBox styleClass="table-panel" spacing="10">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="txtBuscar"
                                   promptText="🔍 Buscar por nombre o cédula..."
                                   styleClass="search-field"
                                   HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <TableView fx:id="tableClientes"
                               styleClass="table-view"
                               VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colId" text="CÓDIGO" prefWidth="80"/>
                            <TableColumn fx:id="colNombre" text="NOMBRE" prefWidth="160"/>
                            <TableColumn fx:id="colCorreo" text="CORREO" prefWidth="160"/>
                            <TableColumn fx:id="colTelefono" text="TELÉFONO" prefWidth="110"/>
                            <TableColumn fx:id="colTarjeta" text="TARJETA" prefWidth="110"/>
                            <TableColumn fx:id="colPuntos" text="PUNTOS" prefWidth="80"/>
                            <TableColumn fx:id="colActivo" text="ESTADO" prefWidth="80"/>
                        </columns>
                    </TableView>

                    <Label text="Seleccione un cliente de la tabla para modificarlo"
                           styleClass="help-label"/>
                </VBox>

            </SplitPane>
        </VBox>
    </center>

</BorderPane>
