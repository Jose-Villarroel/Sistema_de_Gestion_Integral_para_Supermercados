<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.gerente.DashboardController"
            stylesheets="@../base.css,@dashboard.css">

    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">
            <Label text="🛒 MasterMarket" styleClass="top-bar-brand"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label text="Dashboard Gerencial" styleClass="top-bar-context"/>
            <Button text="Cerrar Sesión"
                    onAction="#cerrarSesion"
                    styleClass="btn-cerrar-sesion"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
                <VBox styleClass="content-area" alignment="CENTER" spacing="16">
                    <Label text="Dashboard Gerencial" styleClass="page-title"/>
                    <Label text="Módulo en construcción — Iteración próxima" styleClass="page-subtitle"/>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
