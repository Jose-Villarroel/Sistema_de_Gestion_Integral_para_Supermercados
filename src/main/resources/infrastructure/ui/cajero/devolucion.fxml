<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.cajero.DevolucionController"
            style="-fx-background-color: linear-gradient(to bottom, #f7efe4, #fffdf9);">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="14"
              style="-fx-background-color: #5b2c3a; -fx-padding: 16 22;">
            <Label text="MasterMarket POS"
                   style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;"/>
            <Label text="Procesar Devolucion"
                   style="-fx-text-fill: #e8d0d8; -fx-font-size: 13;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Volver al POS"
                    onAction="#volverPOS"
                    style="-fx-background-color: #8c4759; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
        <content>
        <HBox spacing="18" style="-fx-padding: 18;" minHeight="-Infinity">
            <VBox spacing="14" HBox.hgrow="ALWAYS">
                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 18; -fx-border-color: #eadfcd; -fx-border-radius: 16;">
                    <Label text="Buscar Venta"
                           style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #5b2c3a;"/>
                    <HBox spacing="10">
                        <TextField fx:id="txtIdVenta" promptText="ID de la venta" HBox.hgrow="ALWAYS"/>
                        <Button text="Buscar"
                                onAction="#buscarVenta"
                                style="-fx-background-color: #d86f45; -fx-text-fill: white; -fx-font-weight: bold;"/>
                    </HBox>
                </VBox>

                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 18; -fx-border-color: #eadfcd; -fx-border-radius: 16;">
                    <Label text="Productos disponibles para devolver"
                           style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #5b2c3a;"/>
                    
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Cantidad a devolver:"/>
                        <TextField fx:id="txtCantidadDevolver" promptText="Cant." prefWidth="60"/>
                        <Label text="Motivo producto:"/>
                        <TextField fx:id="txtMotivoProducto" promptText="Motivo" HBox.hgrow="ALWAYS"/>
                        <Button text="Asignar Devolucion"
                                onAction="#asignarCantidadDevolver"
                                style="-fx-background-color: #2e86ab; -fx-text-fill: white;"/>
                    </HBox>

                    <TableView fx:id="tblDetalles" prefHeight="320">
                        <columns>
                            <TableColumn fx:id="colCodigo" text="ID Producto"/>
                            <TableColumn fx:id="colProducto" text="Producto"/>
                            <TableColumn fx:id="colComprada" text="Cant. Comprada"/>
                            <TableColumn fx:id="colDevuelta" text="Ya Devuelta"/>
                            <TableColumn fx:id="colPrecio" text="Precio Pagado"/>
                            <TableColumn fx:id="colADevolver" text="A Devolver"/>
                            <TableColumn fx:id="colMotivo" text="Motivo"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>

            <VBox spacing="14" prefWidth="340">
                <VBox spacing="12"
                      style="-fx-background-color: #fffaf2; -fx-background-radius: 16; -fx-padding: 18; -fx-border-color: #eadfcd; -fx-border-radius: 16;">
                    <Label text="Resumen de Devolucion"
                           style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #5b2c3a;"/>
                    <GridPane hgap="10" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="55"/>
                            <ColumnConstraints percentWidth="45"/>
                        </columnConstraints>
                        <Label text="Total a reembolsar" GridPane.rowIndex="0"
                               style="-fx-font-weight: bold; -fx-text-fill: #5b2c3a;"/>
                        <Label fx:id="lblTotalDevolver" GridPane.columnIndex="1" GridPane.rowIndex="0"
                               style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #d94841;"/>
                    </GridPane>
                </VBox>

                <VBox spacing="12"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 18; -fx-border-color: #eadfcd; -fx-border-radius: 16;">
                    <Label text="Confirmacion"
                           style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #5b2c3a;"/>
                    <TextField fx:id="txtMotivoGeneral" promptText="Motivo general de la devolucion"/>
                    
                    <Button text="Confirmar Devolucion"
                            onAction="#procesarDevolucion"
                            maxWidth="Infinity"
                            style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 14;"/>
                </VBox>

                <VBox spacing="8"
                      style="-fx-background-color: #fceceb; -fx-background-radius: 16; -fx-padding: 16; -fx-border-color: #f1b0b7; -fx-border-radius: 16;">
                    <Label text="Estado de Devolucion"
                           style="-fx-font-weight: bold; -fx-text-fill: #5b2c3a;"/>
                    <Label fx:id="lblMensaje" wrapText="true" style="-fx-text-fill: #a94442;"/>
                </VBox>
            </VBox>
        </HBox>
        </content>
        </ScrollPane>
    </center>

    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>
</BorderPane>
