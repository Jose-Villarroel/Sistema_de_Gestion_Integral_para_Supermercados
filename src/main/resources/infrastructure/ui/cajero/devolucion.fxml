<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.cajero.DevolucionController"
            stylesheets="@../base.css,@devolucion.css">

    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="14">
            <Label text="🛒 MasterMarket" styleClass="top-bar-brand"/>
            <Label text="Procesar Devolución" styleClass="top-bar-context"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Volver al POS"
                    onAction="#volverPOS"
                    styleClass="btn-volver"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
                <HBox spacing="18" style="-fx-padding: 18; -fx-background-color: #F5F2EE;">

                    <!-- Panel izquierdo -->
                    <VBox spacing="14" HBox.hgrow="ALWAYS">

                        <!-- Buscar venta -->
                        <VBox styleClass="panel-card" spacing="10">
                            <Label text="Buscar Venta" styleClass="panel-title"/>
                            <HBox spacing="10">
                                <TextField fx:id="txtIdVenta"
                                           promptText="ID de la venta"
                                           styleClass="text-field"
                                           HBox.hgrow="ALWAYS"/>
                                <Button text="Buscar"
                                        onAction="#buscarVenta"
                                        styleClass="btn-search"/>
                            </HBox>
                        </VBox>

                        <!-- Productos a devolver -->
                        <VBox styleClass="panel-card" spacing="10">
                            <Label text="Productos disponibles para devolver"
                                   styleClass="panel-title"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Cantidad a devolver:"
                                       style="-fx-text-fill: #3A3A3A; -fx-font-size: 12px;"/>
                                <TextField fx:id="txtCantidadDevolver"
                                           promptText="Cant."
                                           styleClass="text-field"
                                           prefWidth="70"/>
                                <Label text="Motivo:"
                                       style="-fx-text-fill: #3A3A3A; -fx-font-size: 12px;"/>
                                <TextField fx:id="txtMotivoProducto"
                                           promptText="Motivo del producto"
                                           styleClass="text-field"
                                           prefWidth="180"/>
                                <Label text="Estado:"
                                       style="-fx-text-fill: #3A3A3A; -fx-font-size: 12px;"/>
                                <ComboBox fx:id="cmbEstadoProducto"
                                          styleClass="combo-box"
                                          prefWidth="140"/>
                                <Button text="Asignar Devolución"
                                        onAction="#asignarCantidadDevolver"
                                        styleClass="btn-assign"/>
                            </HBox>
                            <TableView fx:id="tblDetalles" prefHeight="300"
                                       styleClass="table-view">
                                <columns>
                                    <TableColumn fx:id="colCodigo" text="ID" prefWidth="60"/>
                                    <TableColumn fx:id="colProducto" text="Producto" prefWidth="160"/>
                                    <TableColumn fx:id="colComprada" text="Comprada" prefWidth="85"/>
                                    <TableColumn fx:id="colDevuelta" text="Devuelta" prefWidth="80"/>
                                    <TableColumn fx:id="colPrecio" text="Precio" prefWidth="90"/>
                                    <TableColumn fx:id="colADevolver" text="A Devolver" prefWidth="90"/>
                                    <TableColumn fx:id="colMotivo" text="Motivo" prefWidth="120"/>
                                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="90"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </VBox>

                    <!-- Panel derecho -->
                    <VBox spacing="14" prefWidth="360">

                        <!-- Resumen -->
                        <VBox styleClass="panel-summary" spacing="10">
                            <Label text="Resumen de Devolución" styleClass="panel-title"/>
                            <GridPane hgap="10" vgap="10">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="55"/>
                                    <ColumnConstraints percentWidth="45"/>
                                </columnConstraints>
                                <Label text="Total a reembolsar"
                                       styleClass="summary-total-label"
                                       GridPane.rowIndex="0"/>
                                <Label fx:id="lblTotalDevolver"
                                       styleClass="summary-total-value"
                                       GridPane.columnIndex="1"
                                       GridPane.rowIndex="0"/>
                            </GridPane>
                        </VBox>

                        <!-- Confirmación -->
                        <VBox styleClass="panel-card" spacing="10">
                            <Label text="Confirmación" styleClass="panel-title"/>
                            <TextField fx:id="txtMotivoGeneral"
                                       promptText="Motivo general de la devolución"
                                       styleClass="text-field"/>
                            <ComboBox fx:id="cmbMetodoReembolso"
                                      promptText="Método de reembolso"
                                      styleClass="combo-box"
                                      maxWidth="Infinity"/>
                            <TextField fx:id="txtSupervisorUsuario"
                                       promptText="Usuario supervisor (si aplica)"
                                       styleClass="text-field"/>
                            <PasswordField fx:id="txtSupervisorPassword"
                                           promptText="Clave supervisor (si aplica)"
                                           styleClass="text-field"/>
                            <Button text="Confirmar Devolución"
                                    onAction="#procesarDevolucion"
                                    maxWidth="Infinity"
                                    styleClass="btn-confirm-devolucion"/>
                        </VBox>

                        <!-- Estado -->
                        <VBox styleClass="panel-status-error" spacing="8">
                            <Label text="Estado de Devolución"
                                   styleClass="panel-status-title"/>
                            <Label fx:id="lblMensaje" wrapText="true"
                                   styleClass="panel-status-msg"/>
                        </VBox>

                    </VBox>
                </HBox>
            </content>
        </ScrollPane>
    </center>

    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>
</BorderPane>
