<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.cajero.PosController"
            stylesheets="@../base.css,@pos.css">

    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="14">
            <Label text="🛒 MasterMarket" styleClass="top-bar-brand"/>
            <Label text="Punto de Venta" styleClass="top-bar-context"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox spacing="2">
                <Label text="Cajero" styleClass="top-bar-user-label"/>
                <Label fx:id="lblCajero" styleClass="top-bar-user-name"/>
            </VBox>
            <Button text="Devoluciones"
                    onAction="#abrirDevoluciones"
                    styleClass="btn-topbar"/>
            <VBox spacing="2">
                <Label text="Turno" styleClass="top-bar-user-label"/>
                <ComboBox fx:id="cmbTurno" promptText="Seleccione" prefWidth="130"
                          styleClass="combo-topbar"/>
            </VBox>
            <Button text="Cierre de Caja"
                    onAction="#abrirCierreCaja"
                    styleClass="btn-topbar"/>
            <Button text="Cerrar Sesión"
                    onAction="#cerrarSesion"
                    styleClass="btn-cerrar-sesion"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
                <HBox spacing="18" style="-fx-padding: 18; -fx-background-color: #F5F2EE;">

                    <!-- Columna izquierda -->
                    <VBox spacing="14" HBox.hgrow="ALWAYS">

                        <!-- Escaneo -->
                        <VBox styleClass="panel-card" spacing="10">
                            <Label text="Escaneo y Productos" styleClass="panel-title"/>
                            <HBox spacing="10">
                                <TextField fx:id="txtCodigoProducto"
                                           promptText="ID del producto"
                                           styleClass="text-field"
                                           HBox.hgrow="ALWAYS"/>
                                <Button text="Agregar"
                                        onAction="#agregarProducto"
                                        styleClass="btn-add"/>
                            </HBox>
                            <HBox spacing="10">
                                <TextField fx:id="txtCantidad"
                                           promptText="Nueva cantidad"
                                           styleClass="text-field"
                                           prefWidth="150"/>
                                <Button text="Actualizar cantidad"
                                        onAction="#actualizarCantidad"
                                        styleClass="btn-update"/>
                                <Button text="Eliminar"
                                        onAction="#eliminarProducto"
                                        styleClass="btn-delete"/>
                            </HBox>
                            <TableView fx:id="tblVenta" prefHeight="300"
                                       styleClass="table-view">
                                <columns>
                                    <TableColumn fx:id="colCodigo" text="ID" prefWidth="60"/>
                                    <TableColumn fx:id="colProducto" text="Producto" prefWidth="180"/>
                                    <TableColumn fx:id="colCantidad" text="Cant." prefWidth="65"/>
                                    <TableColumn fx:id="colPrecio" text="P. Unitario" prefWidth="100"/>
                                    <TableColumn fx:id="colSubtotal" text="Subtotal" prefWidth="100"/>
                                    <TableColumn fx:id="colStock" text="Stock" prefWidth="70"/>
                                </columns>
                            </TableView>
                        </VBox>

                        <!-- Cliente y descuentos -->
                        <VBox styleClass="panel-card" spacing="10">
                            <Label text="Cliente, Descuentos y Cierre" styleClass="panel-title"/>
                            <HBox spacing="10">
                                <TextField fx:id="txtCodigoCliente"
                                           promptText="ID cliente o número tarjeta"
                                           styleClass="text-field"
                                           HBox.hgrow="ALWAYS"/>
                                <Button text="Buscar cliente"
                                        onAction="#buscarCliente"
                                        styleClass="btn-client"/>
                            </HBox>
                            <Label fx:id="lblCliente" styleClass="client-info-label"/>
                            <HBox spacing="10">
                                <ComboBox fx:id="cmbTipoDescuento"
                                          styleClass="combo-box"
                                          prefWidth="160"/>
                                <TextField fx:id="txtDescuentoManual"
                                           promptText="Valor o porcentaje"
                                           styleClass="text-field"
                                           prefWidth="140"/>
                                <Button text="Aplicar descuento"
                                        onAction="#aplicarDescuentoManual"
                                        styleClass="btn-discount"/>
                                <Button text="Completar Venta"
                                        onAction="#prepararFinalizacion"
                                        styleClass="btn-complete-sale"/>
                            </HBox>
                            <Label fx:id="lblResumenPago" wrapText="true"
                                   styleClass="payment-summary-label"/>
                        </VBox>
                    </VBox>

                    <!-- Columna derecha -->
                    <VBox spacing="14" prefWidth="340">

                        <!-- Resumen -->
                        <VBox styleClass="panel-summary" spacing="10">
                            <Label text="Resumen de Venta" styleClass="panel-title"/>
                            <GridPane hgap="10" vgap="10">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="55"/>
                                    <ColumnConstraints percentWidth="45"/>
                                </columnConstraints>
                                <Label text="Subtotal" styleClass="summary-row-label"/>
                                <Label fx:id="lblSubtotal" styleClass="summary-row-label"
                                       GridPane.columnIndex="1"/>
                                <Label text="Descuento automático" styleClass="summary-row-label"
                                       GridPane.rowIndex="1"/>
                                <Label fx:id="lblDescuentoAuto" styleClass="summary-row-label"
                                       GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                <Label text="Descuento manual" styleClass="summary-row-label"
                                       GridPane.rowIndex="2"/>
                                <Label fx:id="lblDescuentoManual" styleClass="summary-row-label"
                                       GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                <Label text="Impuestos" styleClass="summary-row-label"
                                       GridPane.rowIndex="3"/>
                                <Label fx:id="lblImpuestos" styleClass="summary-row-label"
                                       GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                                <Separator GridPane.rowIndex="4" GridPane.columnSpan="2"/>
                                <Label text="Total final" styleClass="summary-total-label"
                                       GridPane.rowIndex="5"/>
                                <Label fx:id="lblTotal" styleClass="summary-total-value"
                                       GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                                <Label text="Cambio" styleClass="summary-row-label"
                                       GridPane.rowIndex="6"/>
                                <Label fx:id="lblCambio" styleClass="summary-row-label"
                                       GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                            </GridPane>
                        </VBox>

                        <!-- Pago y ticket -->
                        <VBox styleClass="panel-card" spacing="10">
                            <Label text="Pago y Ticket" styleClass="panel-title"/>
                            <ComboBox fx:id="cmbMetodoPago"
                                      promptText="Método de pago"
                                      onAction="#actualizarSeccionPago"
                                      styleClass="combo-box"
                                      maxWidth="Infinity"/>
                            <TextField fx:id="txtMontoRecibido"
                                       promptText="Monto recibido"
                                       styleClass="text-field"/>
                            <TextField fx:id="txtReferenciaPago"
                                       promptText="Referencia o autorización"
                                       styleClass="text-field"/>
                            <CheckBox fx:id="chkFacturaElectronica"
                                      text="Solicitar factura electrónica"
                                      onAction="#actualizarSeccionPago"
                                      styleClass="check-box"/>
                            <TextField fx:id="txtDatosFacturacion"
                                       promptText="Datos fiscales"
                                       styleClass="text-field"/>
                            <CheckBox fx:id="chkImprimir"
                                      text="Imprimir ticket"
                                      selected="true"
                                      onAction="#actualizarSeccionPago"
                                      styleClass="check-box"/>
                            <CheckBox fx:id="chkEnviarCorreo"
                                      text="Enviar por correo"
                                      onAction="#actualizarSeccionPago"
                                      styleClass="check-box"/>
                            <TextField fx:id="txtCorreoTicket"
                                       promptText="Correo destinatario"
                                       styleClass="text-field"/>
                            <Button text="Confirmar Transacción"
                                    onAction="#confirmarVenta"
                                    maxWidth="Infinity"
                                    styleClass="btn-confirm"/>
                        </VBox>

                        <!-- Estado -->
                        <VBox styleClass="panel-status" spacing="8">
                            <Label text="Estado del POS" styleClass="panel-status-title"/>
                            <Label fx:id="lblMensaje" wrapText="true"
                                   styleClass="panel-status-msg"/>
                        </VBox>

                    </VBox>
                </HBox>
            </content>
        </ScrollPane>
    </center>

    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>
</BorderPane>
