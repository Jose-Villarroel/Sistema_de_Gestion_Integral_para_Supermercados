<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.cajero.PosController"
            style="-fx-background-color: #f5f5f5;">

    <!-- Barra superior -->
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 12 20;"
              alignment="CENTER_LEFT" spacing="16">
            <Label text="🛒 MasterMarket"
                   style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label text="Punto de Venta"
                   style="-fx-text-fill: #bdc3c7; -fx-font-size: 13;"/>
            <Button text="Cerrar Sesión"
                    onAction="#cerrarSesion"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                           -fx-cursor: hand; -fx-border-radius: 4; -fx-background-radius: 4;"/>
        </HBox>
    </top>

    <!-- Contenido central -->
    <center>
        <VBox style="-fx-padding: 40;" alignment="CENTER" spacing="20">

            <Label text="Punto de Venta"
                   style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <Label text="Seleccione una opción"
                   style="-fx-font-size: 14; -fx-text-fill: #7f8c8d;"/>

            <Button text="🧾 Cierre de Caja"
                    onAction="#abrirCierreCaja"
                    style="-fx-background-color: #34495e; -fx-text-fill: white;
                   -fx-font-size: 14; -fx-padding: 10 20;
                   -fx-background-radius: 8; -fx-cursor: hand;"/>

        </VBox>
    </center>

</BorderPane>
