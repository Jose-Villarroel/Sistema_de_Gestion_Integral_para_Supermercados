<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="infrastructure.ui.supervisor.InventarioController">

    <!-- HEADER -->
    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 12 20;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Control de Inventario"
                       style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Cerrar Sesion" onAction="#cerrarSesion"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.4">

            <!-- FORMULARIO -->
            <VBox spacing="15">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <Label text="Registrar Movimiento"
                       style="-fx-font-size: 16; -fx-font-weight: bold;"/>

                <!-- ID producto -->
                <VBox spacing="5">
                    <Label text="ID del Producto *"/>
                    <HBox spacing="8">
                        <TextField fx:id="txtCodigo" promptText="Ej: 1"
                                   HBox.hgrow="ALWAYS"/>
                        <Button text="Buscar" onAction="#buscarProducto"/>
                    </HBox>
                </VBox>

                <Label fx:id="lblInfoProducto" wrapText="true"/>

                <!-- Tipo -->
                <VBox spacing="5">
                    <Label text="Tipo de Movimiento *"/>
                    <ComboBox fx:id="cmbTipo" onAction="#onTipoChanged"/>
                </VBox>

                <!-- Cantidad -->
                <VBox spacing="5">
                    <Label text="Cantidad *"/>
                    <TextField fx:id="txtCantidad"/>
                </VBox>

                <!-- Motivo -->
                <VBox spacing="5">
                    <Label text="Motivo *"/>
                    <ComboBox fx:id="cmbMotivo"/>
                </VBox>

                <!-- Botones -->
                <HBox spacing="10" alignment="CENTER">
                    <Button text="Registrar" onAction="#registrarMovimiento"/>
                    <Button text="Limpiar" onAction="#limpiarFormulario"/>
                </HBox>

            </VBox>

            <!-- TABLA -->
            <VBox spacing="10">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <HBox spacing="10">
                    <TextField fx:id="txtBuscar" promptText="Buscar por ID..."/>
                    <Button text="Alertas" onAction="#verAlertasStock"/>
                </HBox>

                <TableView fx:id="tableMovimientos" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colFecha" text="Fecha"/>
                        <TableColumn fx:id="colTipo" text="Tipo"/>
                        <TableColumn fx:id="colProducto" text="Producto"/>
                        <TableColumn fx:id="colCantidad" text="Cantidad"/>
                        <TableColumn fx:id="colMotivo" text="Motivo"/>
                    </columns>
                </TableView>

            </VBox>

        </SplitPane>
    </center>

</BorderPane>