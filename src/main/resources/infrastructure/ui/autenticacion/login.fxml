<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.autenticacion.LoginController"
           alignment="CENTER"
           style="-fx-background-color: #FFFFFF;"
           stylesheets="@login.css">

    <VBox alignment="CENTER"
          spacing="22"
          maxWidth="420"
          translateY="10">

        <!-- LOGO -->
        <VBox alignment="CENTER" spacing="12">

            <ImageView fitWidth="280"
                       preserveRatio="true">
                <image>
                    <Image url="file:src/main/resources/img/mastermarket_logo.png"/>
                </image>
            </ImageView>

            <Label text="Sistema de Gestión"
                   styleClass="brand-sub"/>
        </VBox>

        <!-- FORMULARIO -->
        <VBox spacing="16" maxWidth="360">

            <VBox spacing="6">
                <Label text="Usuario" styleClass="field-label"/>
                <TextField fx:id="txtUsuario"
                           promptText="Ingresa tu usuario"
                           styleClass="text-field"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Contraseña" styleClass="field-label"/>
                <PasswordField fx:id="txtPassword"
                               promptText="••••••••"
                               styleClass="text-field"/>
            </VBox>

            <Label fx:id="lblError"
                   text=""
                   wrapText="true"
                   styleClass="error-label"/>

            <Button text="INGRESAR AL SISTEMA"
                    onAction="#login"
                    styleClass="login-btn"
                    maxWidth="Infinity"/>
        </VBox>

        <!-- FOOTER -->
        <Label text="v1.0 · Pontificia Universidad Javeriana · 2026"
               styleClass="footer-label"/>

    </VBox>

</StackPane>